{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@kilocode/kilo",
  "description": "AI-powered development platform with enterprise-grade testing, governance, and automation capabilities",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun run --cwd packages/opencode --conditions=browser src/index.ts",
    "dev:desktop": "bun --cwd packages/desktop tauri dev",
    "dev:web": "bun --cwd packages/app dev",
    "dev:storybook": "bun --cwd packages/storybook storybook",
    "typecheck": "bun turbo typecheck",
    "prepare": "husky",
    "test": "bun run lint && bun run typecheck && bun run test:unit",
    "test:all": "bun run test:unit && bun run test:e2e && bun run test:governance",
    "test:governance": "playwright test --project=governance-tests",
    "test:performance": "playwright test --project=performance-tests",
    "test:security": "playwright test --project=security-tests",
    "test:migration": "playwright test --project=migration-tests",
    "test:resilience": "playwright test --project=resilience-tests",
    "test:scalability": "playwright test --project=scalability-tests",
    "test:disaster-recovery": "playwright test --project=disaster-recovery-tests",
    "test:playwright": "playwright test",
    "test:coverage": "playwright test --coverage",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "extension": "bun --cwd packages/kilo-vscode script/launch.ts",
    "lint": "bun --cwd packages/kilo-vscode lint && bun --cwd packages/opencode lint",
    "test:unit": "bun --cwd packages/app test:unit && bun --cwd packages/kilo-vscode test:unit && bun --cwd packages/opencode test && bun --cwd packages/kilo-telemetry test",
    "test:e2e:app": "bun --cwd packages/app test:e2e",
    "test:e2e:vscode": "bun --cwd packages/kilo-vscode test:visual",
    "build:repo": "bun --cwd packages/app build && bun --cwd packages/desktop build && bun --cwd packages/opencode build && bun --cwd packages/kilo-gateway build && bun --cwd packages/kilo-telemetry build && bun --cwd packages/plugin build && bun --cwd packages/storybook build",
    "package:desktop": "bun --cwd packages/desktop-electron package",
    "ci:core": "bun run lint && bun run typecheck && bun run test:unit && bun run format",
    "ci:e2e": "bun run test:e2e:app && bun run test:e2e:vscode",
    "ci:release": "bun run ci:core && bun run build:repo && bun run package:desktop",
    "validate:release": "node scripts/validate-release.js",
    "validate:tests": "node scripts/validate-tests-simple.js",
    "generate:artifacts": "node scripts/generate-artifacts.js"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/sdk/js"
    ],
    "catalog": {
      "@types/bun": "1.3.9",
      "@octokit/rest": "22.0.0",
      "@hono/zod-validator": "0.4.2",
      "ulid": "3.0.1",
      "@kobalte/core": "0.13.11",
      "@types/luxon": "3.7.1",
      "@types/node": "22.13.9",
      "@types/semver": "7.7.1",
      "@tsconfig/node22": "22.0.2",
      "@tsconfig/bun": "1.0.9",
      "@cloudflare/workers-types": "4.20251008.0",
      "@openauthjs/openauth": "0.0.0-20250322224806",
      "@pierre/diffs": "1.1.0-beta.18",
      "@solid-primitives/storage": "4.3.3",
      "@tailwindcss/vite": "4.1.11",
      "diff": "8.0.2",
      "dompurify": "3.3.1",
      "drizzle-kit": "1.0.0-beta.16-ea816b6",
      "drizzle-orm": "1.0.0-beta.16-ea816b6",
      "ai": "5.0.124",
      "hono": "4.10.7",
      "hono-openapi": "1.1.2",
      "fuzzysort": "3.1.0",
      "luxon": "3.6.1",
      "marked": "17.0.1",
      "marked-shiki": "1.2.1",
      "@playwright/test": "1.51.0",
      "typescript": "5.8.2",
      "@typescript/native-preview": "7.0.0-dev.20260316.1",
      "zod": "4.1.8",
      "remeda": "2.26.0",
      "shiki": "3.20.0",
      "solid-list": "0.3.0",
      "tailwindcss": "4.1.11",
      "virtua": "0.42.3",
      "vite": "7.1.4",
      "@solidjs/meta": "0.29.4",
      "@solidjs/router": "0.15.4",
      "@solidjs/start": "https://pkg.pr.new/@solidjs/start@dfb2020",
      "solid-js": "1.9.10",
      "vite-plugin-solid": "2.11.10"
    }
  },
  "devDependencies": {
    "@actions/artifact": "5.0.1",
    "@tsconfig/bun": "catalog:",
    "@types/mime-types": "3.0.1",
    "@typescript/native-preview": "catalog:",
    "glob": "13.0.5",
    "husky": "9.1.7",
    "prettier": "3.8.1",
    "semver": "^7.6.0",
    "sst": "3.18.10",
    "turbo": "2.8.13"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.933.0",
    "@kilocode/plugin": "workspace:*",
    "@kilocode/sdk": "workspace:*",
    "@morphllm/morphsdk": "0.2.141",
    "@opencode-ai/script": "workspace:*",
    "@playwright/test": "1.58.2",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kilo-Org/kilocode"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "development",
    "testing",
    "automation",
    "code-generation",
    "playwright",
    "typescript",
    "enterprise",
    "governance",
    "ci-cd"
  ],
  "release": {
    "version": "7.1.9",
    "date": "2026-03-29",
    "status": "production-ready",
    "features": [
      "enterprise-testing-framework",
      "automated-quality-gates",
      "comprehensive-documentation",
      "advanced-ci-cd",
      "security-scanning",
      "performance-monitoring",
      "governance-compliance"
    ],
    "statistics": {
      "tests": 140,
      "test-categories": 10,
      "documentation-files": 7,
      "cicd-workflows": 25,
      "quality-gates": 8,
      "coverage-target": "80%+"
    }
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "trustedDependencies": [
    "esbuild",
    "protobufjs",
    "tree-sitter",
    "tree-sitter-bash",
    "web-tree-sitter",
    "electron"
  ],
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  },
  "patchedDependencies": {
    "@standard-community/standard-openapi@0.2.9": "patches/@standard-community%2Fstandard-openapi@0.2.9.patch",
    "@openrouter/ai-sdk-provider@1.5.4": "patches/@openrouter%2Fai-sdk-provider@1.5.4.patch",
    "ghostty-web@0.3.0": "patches/ghostty-web@0.3.0.patch"
  },
  "version": "7.1.9",
  "peerDependencies": {}
}