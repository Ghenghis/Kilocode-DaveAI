{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@kilocode/kilo-gateway",
  "version": "7.1.9",
  "type": "module",
  "license": "MIT",
  "description": "API Gateway for Kilo Code services",
  "keywords": [
    "api",
    "gateway",
    "microservices",
    "routing"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./tui": "./src/tui.ts"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "bun run --bun tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "bun run --bun lint",
    "prepublishOnly": "bun run build && bun run test"
  },
  "dependencies": {
    "@kilocode/plugin": "workspace:*",
    "@kilocode/sdk": "workspace:*",
    "@ai-sdk/anthropic": "2.0.65",
    "@ai-sdk/openai": "2.0.101",
    "@ai-sdk/openai-compatible": "1.0.32",
    "@openrouter/ai-sdk-provider": "1.5.4",
    "@clack/prompts": "1.0.0-alpha.1",
    "ai": "catalog:",
    "open": "10.1.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:",
    "solid-js": "1.9.10",
    "@opentui/core": "0.1.75",
    "@opentui/solid": "0.1.75"
  },
  "peerDependencies": {
    "solid-js": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    },
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ghenghis/Kilocode-DaveAI.git",
    "directory": "packages/kilo-gateway"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}