{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@kilocode/sdk",
  "version": "7.1.9",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "bun run --bun tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "bun run --bun lint",
    "prepublishOnly": "bun run build && bun run test"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./v2": "./src/v2/index.ts",
    "./v2/client": "./src/v2/client.ts",
    "./v2/gen/client": "./src/v2/gen/client/index.ts",
    "./v2/server": "./src/v2/server.ts"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@hey-api/openapi-ts": "0.90.10",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  },
  "dependencies": {},
  "peerDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/Ghenghis/Kilocode-DaveAI.git",
    "directory": "packages/sdk/js"
  },
  "description": "SDK for Kilo Code integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "sdk",
    "api",
    "integration",
    "client"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}